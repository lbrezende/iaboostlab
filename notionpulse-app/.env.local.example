# Copy to .env.local and fill in real values.
# DO NOT commit .env.local — it's gitignored.

# OpenAI (server-side only, never exposed to client)
OPENAI_API_KEY=sk-proj-...

# Database (Neon Postgres in prod; falls back to SQLite if unset)
# postgresql://user:password@host/db?sslmode=require
DATABASE_URL=

# Optional: Auth.js secret for session signing (required if you enable auth)
# Generate with: openssl rand -base64 32
AUTH_SECRET=
