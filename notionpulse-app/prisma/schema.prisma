// Notion Pulse — minimal task schema
// Default datasource is SQLite for local dev (no setup required).
// In production, set DATABASE_URL=postgresql://… and change provider="postgresql".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Task {
  id        String   @id @default(cuid())
  title     String
  notes     String?
  dueDate   DateTime?
  priority  String   @default("medium") // low | medium | high
  list      String   @default("Personal")
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([completed, dueDate])
}
